{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lighthouse.com/schemas/ota_search_v1.json",
  "title": "OTA Hotel Search Event",
  "description": "Inbound search event from OTA partner feed",
  "type": "object",
  "required": [
    "arrival_date",
    "departure_date",
    "length_of_stay",
    "user_country",
    "hotel_id",
    "hotel_name",
    "hotel_latitude",
    "hotel_longitude",
    "timestamp",
    "search_results"
  ],
  "additionalProperties": true,
  "properties": {
    "arrival_date": {
      "type": "string",
      "format": "date",
      "description": "Check-in date (YYYY-MM-DD)"
    },
    "departure_date": {
      "type": "string",
      "format": "date",
      "description": "Check-out date (YYYY-MM-DD)"
    },
    "length_of_stay": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365,
      "description": "Number of nights"
    },
    "user_country": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Country name of the searching user"
    },
    "hotel_id": {
      "type": "integer",
      "minimum": 1,
      "description": "Partner hotel identifier"
    },
    "hotel_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "hotel_latitude": {
      "type": "number",
      "minimum": -90,
      "maximum": 90
    },
    "hotel_longitude": {
      "type": "number",
      "minimum": -180,
      "maximum": 180
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Search event timestamp (ISO 8601)"
    },
    "search_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["room_name", "price", "currency"],
        "properties": {
          "room_name": {
            "type": "string",
            "minLength": 1
          },
          "price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "currency": {
            "type": "string",
            "pattern": "^[A-Z]{3}$",
            "description": "ISO 4217 currency code"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
